//NiceReverb
//sample rate: 48000 hz

import("stdfaust.lib");

//fdn topology: (adders : delays : filters) ~ feedback_matrix
//the ~ operator adds one sample implicit delay in feedback
//delay lengths are adjusted to compensate for this

input_gain(x0) =
    x0,
    x0,
    x0,
    x0,
    x0,
    x0,
    x0,
    x0;
fB(x0, x1, x2, x3, x4, x5, x6, x7) =
    0.3174145872*x0 + 0.3174145872*x1 + 0.3174145872*x2 + 0.3174145872*x3 + 0.3174145872*x4 + 0.3174145872*x5 + 0.3174145872*x6 + 0.3174145872*x7,
    0.3174145872*x0 - 0.3174145872*x1 + 0.3174145872*x2 - 0.3174145872*x3 + 0.3174145872*x4 - 0.3174145872*x5 + 0.3174145872*x6 - 0.3174145872*x7,
    0.3174145872*x0 + 0.3174145872*x1 - 0.3174145872*x2 - 0.3174145872*x3 + 0.3174145872*x4 + 0.3174145872*x5 - 0.3174145872*x6 - 0.3174145872*x7,
    0.3174145872*x0 - 0.3174145872*x1 - 0.3174145872*x2 + 0.3174145872*x3 + 0.3174145872*x4 - 0.3174145872*x5 - 0.3174145872*x6 + 0.3174145872*x7,
    0.3174145872*x0 + 0.3174145872*x1 + 0.3174145872*x2 + 0.3174145872*x3 - 0.3174145872*x4 - 0.3174145872*x5 - 0.3174145872*x6 - 0.3174145872*x7,
    0.3174145872*x0 - 0.3174145872*x1 + 0.3174145872*x2 - 0.3174145872*x3 - 0.3174145872*x4 + 0.3174145872*x5 - 0.3174145872*x6 + 0.3174145872*x7,
    0.3174145872*x0 + 0.3174145872*x1 - 0.3174145872*x2 - 0.3174145872*x3 - 0.3174145872*x4 - 0.3174145872*x5 + 0.3174145872*x6 + 0.3174145872*x7,
    0.3174145872*x0 - 0.3174145872*x1 - 0.3174145872*x2 + 0.3174145872*x3 - 0.3174145872*x4 + 0.3174145872*x5 + 0.3174145872*x6 - 0.3174145872*x7;
output_gain(x0, x1, x2, x3, x4, x5, x6, x7) =
    0.125*x0 + 0.125*x1 + 0.125*x2 + 0.125*x3 + 0.125*x4 + 0.125*x5 + 0.125*x6 + 0.125*x7;

process = (input_gain : ((ro.interleave(8, 2) : par(i, 8, +) : ((@(966) , @(1102) , @(1248) , @(1398) , @(1558) , @(1720) , @(1900) , @(2088)) : (fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0) , fi.tf2(0.65, 0, 0, -0.35, 0)))) ~ fB) : output_gain);
